{
  "name": "kattour",
  "version": "1.1.0",
  "description": "Kattour CLI and compiler for building websites, dashboards and apps with a clarity-first UI language.",
  "type": "module",
  "bin": {
    "kattour": "./bin/kattour.js"
  },
  "files": [
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "node ./scripts/verify-bin.mjs",
    "typecheck": "node ./scripts/verify-bin.mjs",
    "prepublishOnly": "pnpm build && pnpm typecheck"
  },
  "keywords": [
    "kattour",
    "ui-language",
    "compiler",
    "cli",
    "website-builder",
    "dashboard",
    "admin-panel"
  ],
  "license": "MIT",
  "dependencies": {
    "@kattour/cli": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
