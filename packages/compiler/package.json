{
  "name": "@kattour/compiler",
  "version": "1.1.0",
  "description": "Compiler-first UI language engine for Kattour: parser, analyzer, secure renderer, built-in modules and diagnostics.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm typecheck"
  },
  "keywords": [
    "kattour",
    "compiler",
    "ui-language",
    "declarative-ui",
    "dashboard",
    "admin-panel",
    "static-site"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "latest"
  },
  "publishConfig": {
    "access": "public"
  }
}
